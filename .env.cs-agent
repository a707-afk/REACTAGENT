# Customer Service AI Agent Backend - Environment Configuration
# Copy as .env and fill in API keys

# === App Identity ===
APP_NAME=cs-agent-backend
DEBUG=false

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/cs_agent.db

# === LLM: Zhipu (for chat, query rewrite, agent) ===
ZHIPUAI_API_KEY=
ZHIPU_CHAT_MODEL=glm-4-flash
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4/

# === RAG: Data Paths (Customer Service Corpus) ===
DOCS_DIR=data/docs_cs
QDRANT_COLLECTION_NAME=cs_agent
QDRANT_PATH=data/qdrant_cs_local
VECTOR_BACKEND=qdrant
BM25_CORPUS_PATH=data/bm25_cs_corpus.jsonl

# === Embedding Model (GPU) ===
# Point to your local Qwen3-Embedding model path
QWEN_EMBEDDING_MODEL_PATH=C:\Users\Lenovo\.cache\modelscope\hub\models\Qwen\Qwen3-Embedding-0___6B
INFERENCE_DEVICE=cuda

# === Chunking ===
CHUNK_STRATEGY=markdown_heading_overlap
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# === Reranker ===
RERANK_ENABLED=true
RERANK_BACKEND=auto
RERANK_MODEL=C:\Users\Lenovo\.cache\modelscope\hub\models\Qwen\Qwen3-Reranker-0___6B
RERANK_CANDIDATE_TOP_K=20
QWEN_RERANK_MAX_LENGTH=8192
QWEN_RERANK_BATCH_SIZE=4

# === Hybrid Search ===
HYBRID_BM25_ENABLED=true
BM25_CANDIDATE_TOP_K=20
HYBRID_FUSION=rrf
HYBRID_RRF_K=60
HYBRID_SCORE_NORMALIZE=true

# === Retrieval Gate ===
RETRIEVAL_GATE_ENABLED=true
RETRIEVAL_SIMILARITY_THRESHOLD=0.5
RETRIEVAL_SCORE_HIGHER_IS_BETTER=true
REFUSAL_NO_RESULTS=I could not find relevant information in the knowledge base.
REFUSAL_GATE_FAIL=I could not find sufficiently relevant information.

# === Query Rewrite ===
QUERY_REWRITE_MODE=auto

# === Domain Router ===
DOMAIN_ROUTER_ENABLED=true
DOMAIN_ROUTER_PROFILES_PATH=data/domain_router_profiles_cs.json
DOMAIN_ROUTER_ENHANCED=true
DOMAIN_ROUTER_EMBEDDING_ENABLED=true
DOMAIN_ROUTER_HARD_FILTER=false
DOMAIN_ROUTER_SOFT_BOOST_ENABLED=false

# === Access Control ===
ACCESS_POST_FILTER_SAFETY_NET=false

# === Behavior Guard ===
BEHAVIOR_GUARD_ENABLED=true
BEHAVIOR_GUARD_RULES_PATH=data/behavior_rules.default.json

# === Policy Engine ===
POLICY_EMBEDDING_GUARD=false
POLICY_EMBEDDING_THRESHOLD=0.72
POLICY_LLM_GUARD=false
POLICY_LLM_CONFIDENCE=0.8
POLICY_AUDIT_LOG_PATH=logs/policy_audit.jsonl

# === OPA ===
OPA_ENABLED=false
OPA_URL=http://localhost:8181
OPA_POLICY_PATH=rag/allow
OPA_FAIL_OPEN=true

# === Multi-Agent ===
AGENT_MULTI_AGENT_ENABLED=false
AGENT_GRAPH_MODE=linear

# === Observability ===
OTEL_ENABLED=false
OTEL_SERVICE_NAME=cs-agent-backend
LANGFUSE_ENABLED=false

# === Server ===
GRADIO_SERVER_PORT=7860
RAG_API_BASE=http://127.0.0.1:8000
