# Local dev override. Copy to docker-compose.override.yml to expose internal
# services on the host (for local debugging ONLY — never commit the copy).
#
#   cp docker-compose.override.yml.example docker-compose.override.yml
#
# docker compose merges this file with docker-compose.yml automatically.

services:
  qdrant:
    ports:
      - "6333:6333"
    networks:
      - default
      - internal

  postgres:
    ports:
      - "5432:5432"
    networks:
      - default
      - internal

  redis:
    ports:
      - "6379:6379"
    networks:
      - default
      - internal
