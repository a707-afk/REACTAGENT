# 复制为 .env 后填写（勿提交 .env）
# 智谱：与系统/用户环境变量二选一即可（pydantic 会读 ZHIPUAI_API_KEY 或 ZHIPU_API_KEY）
ZHIPUAI_API_KEY=

# 检索前 Query Rewrite（未设置时代码默认为 auto，勿与「默认关闭」混淆）：off=永不调用智谱改写 | on=有 Key 则每次改写 | auto=启发式门控后条件调用智谱，并非由 LLM 单独裁决「要不要改写」
# QUERY_REWRITE_MODE=auto

# 可选：覆盖本地 Embedding 目录（默认见 app/config.py 中 ModelScope 路径）
# QWEN_EMBEDDING_MODEL_PATH=C:\Users\Lenovo\.cache\modelscope\hub\models\Qwen\Qwen3-Embedding-0___6B

# 可选
# ZHIPU_CHAT_MODEL=glm-4-flash
# ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4/
# CHUNK_STRATEGY=markdown_heading_overlap
# CHUNK_SIZE_TOKENS=512
# CHUNK_OVERLAP_TOKENS=64
# CHROMA_PERSIST_DIR=data/chroma
# CHROMA_COLLECTION_NAME=rag_kb
# DOCS_DIR=data/docs
# APP_NAME=enterprise-rag-kb
# DEBUG=false

# 混合检索：BM25（jieba 分词）+ 向量宽召回合并后再 Rerank（语料在 reindex 时写入 data/bm25_corpus.jsonl）
# HYBRID_BM25_ENABLED=true
# BM25_CANDIDATE_TOP_K=20
# BM25_CORPUS_PATH=data/bm25_corpus.jsonl

# Rerank：Qwen3-Reranker 为 CausalLM，不可用 CrossEncoder；RERANK_BACKEND=auto 会根据本地 config.json 推断
# RERANK_ENABLED=true
# RERANK_BACKEND=auto
# RERANK_MODEL=C:\Users\Lenovo\.cache\modelscope\hub\models\Qwen\Qwen3-Reranker-0___6B
# RERANK_CANDIDATE_TOP_K=20
# QWEN_RERANK_MAX_LENGTH=8192
# QWEN_RERANK_BATCH_SIZE=4
# 若改用 HuggingFace CrossEncoder（如 BAAI/bge-reranker-base）：设置 RERANK_BACKEND=cross_encoder

# K2 门控：重排后 Top-1 分与阈值比较（Qwen 输出为概率，可与 0.6 对照 eval 再调）
# RETRIEVAL_GATE_ENABLED=true
# RETRIEVAL_SIMILARITY_THRESHOLD=0.6
# RETRIEVAL_SCORE_HIGHER_IS_BETTER=true
# REFUSAL_NO_RESULTS=知识库中无相关内容
# REFUSAL_GATE_FAIL=知识库中无相关内容

# 本地 torch：Embedding + Qwen Reranker。auto=检测到 NVIDIA CUDA 用 GPU，否则 CPU（外接独显/核显切换建议 auto）
# INFERENCE_DEVICE=auto
#
# 策略护栏（演示）：命中则 /chat、/retrieve 短路，不跑完整 RAG
# BEHAVIOR_GUARD_ENABLED=true
# BEHAVIOR_GUARD_RULES_PATH=path/to/rules.json

# Gradio（scripts/gradio_app.py）默认端口
# GRADIO_SERVER_PORT=7860
# RAG_API_BASE=http://127.0.0.1:8000
