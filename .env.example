# ── Database ──
DATABASE_URL=postgresql+asyncpg://ecomagent:ecomagent@localhost:5432/ecomagent
# DATABASE_URL=sqlite+aiosqlite:///./data/ecom_agent.db   # dev only

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── Vector Store ──
QDRANT_URL=http://localhost:6333
# QDRANT_PATH=data/qdrant_local  # unset = use QDRANT_URL (server mode)
# QDRANT_API_KEY=

# ── Embedding Model (sentence-transformers compatible) ──
EMBEDDING_MODEL_NAME=BAAI/bge-m3
# EMBEDDING_MODEL_PATH=/root/models/BAAI/bge-m3  # override if local
RERANKER_MODEL_PATH=
INFERENCE_DEVICE=auto

# ── LLM (SenseNova DeepSeek-V4) ──
SENSENOVA_API_KEYS=sk-your-key-here
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_MODEL=deepseek-v4-flash

# ── Auth ──
API_AUTH_ENABLED=false
API_KEYS=dev-key

# ── API ──
CORS_ORIGINS=*

# ── Agent ──
AGENT_HARNESS_UNIFIED=false
AGENT_REFUND_HITL_THRESHOLD=500
AUTH_FAILURE_RATE_LIMIT=5

# ── Docs / Data ──
DOCS_DIR=data/docs
QDRANT_COLLECTION_NAME=rag_kb
