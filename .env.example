# 复制为 .env 后填写（勿提交 .env）
# 智谱：与系统/用户环境变量二选一即可（pydantic 会读 ZHIPUAI_API_KEY 或 ZHIPU_API_KEY）
ZHIPUAI_API_KEY=

# 检索前 Query Rewrite（未设置时代码默认为 auto，勿与「默认关闭」混淆）：off=永不调用智谱改写 | on=有 Key 则每次改写 | auto=启发式门控后条件调用智谱，并非由 LLM 单独裁决「要不要改写」
# QUERY_REWRITE_MODE=auto

# 可选：覆盖本地 Embedding 目录（默认见 app/config.py 中 ModelScope 路径）
# QWEN_EMBEDDING_MODEL_PATH=C:\Users\Lenovo\.cache\modelscope\hub\models\Qwen\Qwen3-Embedding-0___6B

# 可选
# ZHIPU_CHAT_MODEL=glm-4-flash
# ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4/
# CHUNK_STRATEGY=markdown_heading_overlap
# CHUNK_SIZE_TOKENS=512
# CHUNK_OVERLAP_TOKENS=64
# CHROMA_PERSIST_DIR=data/chroma
# CHROMA_COLLECTION_NAME=rag_kb
# DOCS_DIR=data/docs
#
# 向量后端（默认 auto：有 Qdrant 数据则用 qdrant，否则 chroma；见 docs/QDRANT-NEXT.md）
# VECTOR_BACKEND=auto
# VECTOR_BACKEND=chroma
# VECTOR_BACKEND=qdrant
# QDRANT_PATH=data/qdrant_local
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# 访问控制：有 user_context 时默认检索前 Pre-filter；仅调试时可开 Post-filter 兜底
# ACCESS_POST_FILTER_SAFETY_NET=false
# 混合召回：合并前将 BM25 与向量分各自 min-max 到 [0,1]，减轻 BM25 压过向量
# HYBRID_SCORE_NORMALIZE=true
# APP_NAME=enterprise-rag-kb
# DEBUG=false

# 领域路由：推断结果写入 router_trace；默认不做按域硬性淘汰（生产建议 HARD_FILTER=false）
# DOMAIN_ROUTER_ENABLED=true
# DOMAIN_ROUTER_HARD_FILTER=false
# DOMAIN_ROUTER_STRICT=false              # 仅 HARD_FILTER=true
# DOMAIN_ROUTER_FALLBACK_ALL=true       # 仅 HARD_FILTER=true
#
# Enhanced / Embedding / 多域 / 校准（见 docs/ADR-domain-router-default.md）
# DOMAIN_ROUTER_ENHANCED=true
# DOMAIN_ROUTER_USE_EMBEDDING=true      # Embedding Router 开关
# DOMAIN_ROUTER_PROFILES_PATH=data/domain_router_profiles.json
# ROUTER_CALIBRATION_PATH=              # 空则读 data/router_calibration.default.json
# DOMAIN_ROUTER_FUSION_RULE_WEIGHT=0.55
# DOMAIN_ROUTER_FUSION_EMBEDDING_WEIGHT=0.45
# DOMAIN_ROUTER_MULTIDOMAIN_SECONDARY_RATIO=0.45
# DOMAIN_ROUTER_TOP_DOMAINS_K=3
# DOMAIN_ROUTER_EMBEDDING_FALLBACK_LLM_MAX_SIM=0.38
# DOMAIN_ROUTER_FUSED_FALLBACK_LLM_THRESHOLD=0.22
# DOMAIN_ROUTER_LLM_FALLBACK_ENABLED=true   # 需 ZHIPU Key
#
# 软加权（可选，默认关）：不删候选，仅微调排序信号
# DOMAIN_ROUTER_SOFT_BOOST_ENABLED=false   # 或别名 DOMAIN_ROUTER_SOFT_BOOST=false
# DOMAIN_ROUTER_SOFT_BOOST_TOP_CHUNKS=3
# DOMAIN_ROUTER_SOFT_BOOST_DELTA=0.07

# 混合检索：BM25（jieba 分词）+ 向量宽召回合并后再 Rerank（语料在 reindex 时写入 data/bm25_corpus.jsonl）
# HYBRID_BM25_ENABLED=true
# BM25_CANDIDATE_TOP_K=20
# BM25_CORPUS_PATH=data/bm25_corpus.jsonl

# Rerank：Qwen3-Reranker 为 CausalLM，不可用 CrossEncoder；RERANK_BACKEND=auto 会根据本地 config.json 推断
# RERANK_ENABLED=true
# RERANK_BACKEND=auto
# RERANK_MODEL=C:\Users\Lenovo\.cache\modelscope\hub\models\Qwen\Qwen3-Reranker-0___6B
# RERANK_CANDIDATE_TOP_K=20
# QWEN_RERANK_MAX_LENGTH=8192
# QWEN_RERANK_BATCH_SIZE=4
# 若改用 HuggingFace CrossEncoder（如 BAAI/bge-reranker-base）：设置 RERANK_BACKEND=cross_encoder

# K2 门控：重排后 Top-1 分与阈值比较（Qwen 输出为概率，可与 0.6 对照 eval 再调）
# RETRIEVAL_GATE_ENABLED=true
# RETRIEVAL_SIMILARITY_THRESHOLD=0.6
# RETRIEVAL_SCORE_HIGHER_IS_BETTER=true
# REFUSAL_NO_RESULTS=知识库中无相关内容
# REFUSAL_GATE_FAIL=知识库中无相关内容

# 本地 torch：Embedding + Qwen Reranker。auto=有 CUDA 用 GPU，否则 CPU（不写死；无 GPU 勿设 cuda）
# RTX 5070/50 系需 cu128 版 PyTorch：scripts/setup_pytorch_cuda.ps1，见 docs/CUDA-SETUP.md
# INFERENCE_DEVICE=auto
# INFERENCE_DEVICE=cuda
# INFERENCE_DEVICE=cpu
#
# 策略护栏（演示）：命中则 /chat、/retrieve 短路，不跑完整 RAG
# BEHAVIOR_GUARD_ENABLED=true
# BEHAVIOR_GUARD_RULES_PATH=path/to/rules.json

# scripts/run_eval_retrieve.py：企业评估集或 EVAL_ENTERPRISE_STRICT=1 时校验 DOCS_DIR/collection；EVAL_STRICT_ENTERPRISE=1 时未对齐 enterprise_ai_ops 则退出码 2
# EVAL_ENTERPRISE_STRICT=0
# EVAL_STRICT_ENTERPRISE=0

# 策略引擎扩展（app/policy/engine.py）：向量相似护栏 / 智谱 JSON 分类 / 审计 JSONL（仅写入 policy 日志器）
# POLICY_EMBEDDING_GUARD=false
# POLICY_EMBEDDING_THRESHOLD=0.72
# POLICY_LLM_GUARD=false
# POLICY_LLM_CONFIDENCE=0.8
# POLICY_AUDIT_LOG_PATH=logs/policy_audit.jsonl

# 检索意图加权（rerank 前；默认开启）
# RETRIEVAL_INTENT_BOOST_ENABLED=true
# RETRIEVAL_INTENT_BOOST_DELTA=0.08
# RETRIEVAL_INTENT_PENALTY=0.05
# RETRIEVAL_INTENT_BOOST_MAX_CHUNKS=8

# OPA 外部策略（默认关，fail-open）
# OPA_ENABLED=false
# OPA_URL=http://localhost:8181
# OPA_POLICY_PATH=rag/allow
# OPA_FAIL_OPEN=true

# 多 Agent 图（supervisor + escalation 桩）
# AGENT_MULTI_AGENT_ENABLED=false
# AGENT_GRAPH_MODE=linear

# OpenTelemetry / Langfuse（未安装依赖时 no-op）
# OTEL_ENABLED=false
# OTEL_SERVICE_NAME=enterprise-rag-kb
# OTEL_EXPORTER_OTLP_ENDPOINT=
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com

# Gradio（scripts/gradio_app.py）默认端口
# GRADIO_SERVER_PORT=7860
# RAG_API_BASE=http://127.0.0.1:8000

# 企业知识库 + Agent live eval（与 README「企业场景知识库」一致）
# DOCS_DIR=data/docs/enterprise_ai_ops
# CHROMA_COLLECTION_NAME=enterprise_ai_ops
# BM25_CORPUS_PATH=data/bm25_enterprise_corpus.jsonl
# EVAL_ENTERPRISE_STRICT=1
# AGENT_LIVE_CASE_IDS=AT-005,AT-011,AT-014,AT-015
# AGENT_SMOKE_SKIP=0
# AGENT_SMOKE_WITH_CONTEXT=0
