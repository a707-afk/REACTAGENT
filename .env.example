# EcomAgent — Environment Configuration
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── SensNova (商汤) LLM ──────────────────────────────────────────
# Comma-separated API keys for key rotation
SENSENOVA_API_KEYS=sk-xxx,sk-yyy

# Base URL (SenseNova OpenAI-compatible endpoint)
# Default: https://token.sensenova.cn/v1
# SENSENOVA_BASE_URL=https://token.sensenova.cn/v1

# VLM model for multimodal OCR (image/PDF)
# Default: sensenova-6.7-flash-lite
# VLM_MODEL=sensenova-6.7-flash-lite

# ── Database ─────────────────────────────────────────────────────
# SQLite (default, dev)
DATABASE_URL=sqlite+aiosqlite:///./data/ecom_agent.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://ecomagent:ecomagent@localhost:5432/ecomagent

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=

# ── Qdrant (Vector Database) ─────────────────────────────────────
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_PATH=data/qdrant_local  # 使用本地嵌入式 Qdrant 时不设 QDRANT_URL

# ── Embedding Model ──────────────────────────────────────────────
QWEN_EMBEDDING_MODEL_PATH=models/Qwen/Qwen3-Embedding-0___6B
INFERENCE_DEVICE=auto  # auto | cuda | cpu

# ── Reranker ─────────────────────────────────────────────────────
RERANK_ENABLED=true
RERANK_BACKEND=auto  # auto | qwen3_causal | cross_encoder

# ── Document Ingestion ───────────────────────────────────────────
DOCS_DIR=data/docs_cn
DOCS_DIR_CN=data/docs_cn

# ── Retrieval ────────────────────────────────────────────────────
# Gate threshold (lower = more permissive)
RETRIEVAL_SIMILARITY_THRESHOLD=0.3
RETRIEVAL_GATE_STRICT_MODE=false

# ── Domain Router ────────────────────────────────────────────────
DOMAIN_ROUTER_ENABLED=true
DOMAIN_ROUTER_HARD_FILTER=false

# ── Behavior Guard ───────────────────────────────────────────────
BEHAVIOR_GUARD_ENABLED=true

# ── Agent ────────────────────────────────────────────────────────
AGENT_MULTI_AGENT_ENABLED=false
AGENT_GRAPH_MODE=linear
AGENT_GRAPH_RECURSION_LIMIT=20

# ── API ──────────────────────────────────────────────────────────
API_AUTH_ENABLED=true
API_KEYS=sk-test-key-12345,sk-another-key

# ── Observability (Optional) ─────────────────────────────────────
OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
