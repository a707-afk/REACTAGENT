# ── Database ──
# Production: PostgreSQL (mandatory, no SQLite fallback)
DATABASE_URL=postgresql+asyncpg://ecomagent:ecomagent@localhost:5432/ecomagent

# ── Redis ──
# Required for task queue, distributed cache, rate limiting
REDIS_URL=redis://localhost:6379/0

# ── Vector Store ──
# Production: always use Qdrant server mode (Docker)
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=rag_kb

# ── Embedding Model ──
# Sentence-transformers compatible model (default: BAAI/bge-m3)
# For production set INFERENCE_DEVICE=cuda for GPU
EMBEDDING_MODEL_NAME=BAAI/bge-m3
# EMBEDDING_MODEL_PATH=/root/models/BAAI/bge-m3
INFERENCE_DEVICE=auto

# ── Reranker ──
# Default: BAAI/bge-reranker-v2-m3 (set RERANKER_MODEL_PATH for local model)
RERANK_ENABLED=true
# RERANKER_MODEL_PATH=/root/models/bge-reranker-v2-m3

# ── LLM (SenseNova DeepSeek-V4) ──
# Get keys from SenseNova console. Never commit real keys.
SENSENOVA_API_KEYS=<your-key-1>,<your-key-2>
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
LLM_MODEL=deepseek-v4-flash

# ── Auth (production: enabled by default) ──
API_AUTH_ENABLED=true
API_KEYS=change-this-to-your-api-key
API_RATE_LIMIT_RPM=120

# ── API ──
CORS_ORIGINS=*
DEBUG=false

# ── Agent ──
# Unified Harness (default: true) - replaces LangGraph path
AGENT_HARNESS_UNIFIED=true
AGENT_REFUND_HITL_THRESHOLD=500
AGENT_STEP_TIMEOUT_SECONDS=30.0

# ── Security ──
# OPA policy engine (default: enabled)
OPA_ENABLED=true
# OPA_URL=http://opa:8181

# ── Observability ──
# METRICS_ENABLED=true

# ── Docs / Data ──
DOCS_DIR=data/docs
BM25_CORPUS_PATH=data/bm25_corpus.jsonl
HYBRID_BM25_ENABLED=true
HYBRID_FUSION=max
RETRIEVAL_GATE_ENABLED=true
RETRIEVAL_SIMILARITY_THRESHOLD=0.3
QUERY_REWRITE_MODE=auto
