# CS Agent Backend — DSW Server Environment
# 2026-06-09

APP_NAME=cs-agent-backend
DEBUG=false

# Database (SQLite on server)
DATABASE_URL=sqlite+aiosqlite:///./data/cs_agent.db

# LLM: SenseNova DeepSeek-V4 (3 keys, comma-separated for round-robin)
SENSENOVA_API_KEYS=REDACTED_KEY,REDACTED_KEY,REDACTED_KEY

# Embedding Model (local GPU)
QWEN_EMBEDDING_MODEL_PATH=/mnt/workspace/rag-kb-project/models/Qwen/Qwen3-Embedding-0___6B
INFERENCE_DEVICE=cuda

# Qdrant (local mode, dual collection)
QDRANT_PATH=data/qdrant_local
QDRANT_COLLECTION_NAME=rag_kb
QDRANT_COLLECTION_NAME_CN=kb_cn_general
VECTOR_BACKEND=qdrant

# Data paths
DOCS_DIR=data/docs_cs
DOCS_DIR_CN=data/docs_cn
BM25_CORPUS_PATH=data/bm25_corpus.jsonl
BM25_CORPUS_PATH_CN=data/bm25_cn_corpus.jsonl

# Chunking
CHUNK_STRATEGY=markdown_heading_overlap
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# Reranker (local GPU)
RERANK_ENABLED=true
RERANK_BACKEND=auto
RERANK_MODEL=/mnt/workspace/rag-kb-project/models/Qwen/Qwen3-Reranker-0___6B
RERANK_CANDIDATE_TOP_K=20

# Hybrid Search
HYBRID_BM25_ENABLED=true
BM25_CANDIDATE_TOP_K=20
HYBRID_FUSION=max
HYBRID_RRF_K=60
HYBRID_SCORE_NORMALIZE=true

# Retrieval Gate
RETRIEVAL_GATE_ENABLED=true
RETRIEVAL_SIMILARITY_THRESHOLD=0.6
RETRIEVAL_SCORE_HIGHER_IS_BETTER=true
REFUSAL_NO_RESULTS=知识库中未找到相关信息，请尝试换个方式提问。
REFUSAL_GATE_FAIL=知识库中无足够相关信息，建议转人工客服处理。

# Query Rewrite
QUERY_REWRITE_MODE=auto

# Domain Router
DOMAIN_ROUTER_ENABLED=true
DOMAIN_ROUTER_HARD_FILTER=false
DOMAIN_ROUTER_PROFILES_PATH=data/domain_router_profiles.json

# Access Control
ACCESS_POST_FILTER_SAFETY_NET=false

# Behavior Guard
BEHAVIOR_GUARD_ENABLED=true
BEHAVIOR_GUARD_RULES_PATH=data/behavior_rules.default.json

# Policy Engine
POLICY_EMBEDDING_GUARD=false
POLICY_LLM_GUARD=false

# Multi-Agent
AGENT_MULTI_AGENT_ENABLED=false
AGENT_GRAPH_MODE=linear

# Observability
OTEL_ENABLED=false
LANGFUSE_ENABLED=false

# API
API_AUTH_ENABLED=false
API_RATE_LIMIT_RPM=120
LLM_MAX_RETRIES=2
LLM_TIMEOUT_SECONDS=60
API_AGENT_TIMEOUT_SECONDS=120